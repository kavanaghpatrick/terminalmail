# TerminalMail Environment Variables

# GitHub Token (already set in GH_TOKEN)
GH_TOKEN=ghp_replace_with_your_token

# Google OAuth2 Credentials for Gmail API
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/callback

# OpenAI API Key (for Phase 2 AI features)
OPENAI_API_KEY=sk_replace_with_your_openai_key

# Grok API Key (for code reviews)
GROK_API_KEY=xai_replace_with_your_grok_key

# Gemini API Key (for validation)
GEMINI_API_KEY=replace_with_your_gemini_key